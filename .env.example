# .env.example — copiar para hermes/.env (gitignored).
# Local (compose): hermes/.env é o env COMPLETO (risk-gateway, webhook-shim).
# O serviço do agente usa hermes/.env.agent = .env SEM o token de trading:
#   grep -vE '^BETRADER_(TOKEN|BASE_URL)=' hermes/.env > hermes/.env.agent
# NUNCA commitar hermes/.env* nem colocar valores reais neste arquivo.
#
# Separação de credenciais (F2):
#   - BETRADER_TOKEN é consumido EXCLUSIVAMENTE pelo risk-gateway; JAMAIS entra
#     no container do agente (nem via env_file).
#   - O agente (gateway) usa GATEWAY_URL + GATEWAY_TOKEN para chamar o risk-gateway.

# --- betrader REST API (consumido pelo risk-gateway) ---
BETRADER_BASE_URL=http://betrader.fabiosiqueira.dev
BETRADER_TOKEN=bht_xxx
BETRADER_USER=user@example.com

# --- Risk Gateway (F2) ---
# Token de autenticação entre o agente e o risk-gateway (Authorization: Bearer).
# Gere com: python -c "import secrets; print('gwt_' + secrets.token_hex(32))"
GATEWAY_TOKEN=gwt_xxx

# --- modo de execução ---
EXECUTION_MODE=DRY_RUN
EMERGENCY_STOP=false
INITIAL_EQUITY=1000

# --- símbolo e timeframe do estrategista ---
SYMBOL=BTCUSDT
TIMEFRAME=15m

# --- LLMs ---
MINIMAX_API_KEY=your_minimax_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789
TELEGRAM_HOME_CHANNEL=-100xxxxxxxxxx

# --- Webhook shim (betrader → engine) ---
# Secret HMAC compartilhado: betrader assina → shim verifica → engine re-valida.
# Use o mesmo valor em BETRADER_WEBHOOK_SECRET e WEBHOOK_SECRET.
BETRADER_WEBHOOK_SECRET=whsec_xxx
WEBHOOK_SECRET=whsec_xxx
# URL pública que as automations-sentinela do betrader chamam.
WEBHOOK_PUBLIC_URL=https://<host-publico>/hook/betrader

# --- GitHub (HAWK abre issues no repo fabiosiqueira/hermes-binance) ---
# Token com scope `repo`. Prod: GITHUB_TOKEN (Coolify). Local: GH_TOKEN (override).
GITHUB_TOKEN=
